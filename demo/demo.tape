# lark-retro Demo — VHS Recording Script
# https://github.com/charmbracelet/vhs

Output assets/demo.gif

Set Theme "Catppuccin Mocha"
Set FontFamily "JetBrains Mono"
Set FontSize 14
Set Width 880
Set Height 680
Set Padding 16
Set TypingSpeed 0ms
Set PlaybackSpeed 1

Type "bash demo/simulate.sh"
Enter
Sleep 26s
